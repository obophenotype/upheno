Prefix(:=<http://purl.obolibrary.org/obo/upheno.owl#>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)
Prefix(dcterms:=<http://purl.org/dc/terms/>)


Ontology(<http://purl.obolibrary.org/obo/upheno.owl>
Import(<http://purl.obolibrary.org/obo/upheno/components/upheno-alignments.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/components/upheno-axiom-injections.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/components/upheno-bridge.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/components/upheno-deprecated.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/components/upheno-manual-curation.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/components/upheno-mappings.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/components/upheno-relations.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/components/upheno-special-inference-rules.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/components/upheno-top.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/imports/merged_import.owl>)
Import(<http://purl.obolibrary.org/obo/upheno/patterns/definitions.owl>)
Annotation(<http://purl.obolibrary.org/obo/IAO_0000700> <http://purl.obolibrary.org/obo/UPHENO_0001001>)
Annotation(dcterms:description "The Unified Phenotype Ontology (uPheno) is an ontology that integrates other species-specific phenotype ontologies.")
Annotation(dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/>)
Annotation(dcterms:title "Unified Phenotype Ontology (uPheno)")

Declaration(Class(<http://purl.obolibrary.org/obo/UPHENO_1000001>))
Declaration(Class(<http://purl.obolibrary.org/obo/UPHENO_1000002>))
Declaration(AnnotationProperty(<http://purl.obolibrary.org/obo/IAO_0000700>))
Declaration(AnnotationProperty(dcterms:contributor))
Declaration(AnnotationProperty(dcterms:date))
Declaration(AnnotationProperty(dcterms:title))


############################
#   Classes
############################

# Class: <http://purl.obolibrary.org/obo/UPHENO_0002712> (connective tissue phenotype)

SubClassOf(<http://purl.obolibrary.org/obo/UPHENO_0002712> <http://purl.obolibrary.org/obo/UPHENO_0002963>)

# Class: <http://purl.obolibrary.org/obo/UPHENO_0002725> (alimentary part of gastrointestinal system phenotype)

