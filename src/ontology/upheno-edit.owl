# Class: <http://purl.obolibrary.org/obo/UPHENO_0002832> (renal system phenotype)

SubClassOf(<http://purl.obolibrary.org/obo/UPHENO_0002832> <http://purl.obolibrary.org/obo/UPHENO_0002963>)

# Class: <http://purl.obolibrary.org/obo/UPHENO_0002963> (anatomical system phenotype)

SubClassOf(<http://purl.obolibrary.org/obo/UPHENO_0002963> <http://purl.obolibrary.org/obo/UPHENO_0001001>)

# Class: <http://purl.obolibrary.org/obo/UPHENO_0003432> (musculature of body phenotype)

SubClassOf(<http://purl.obolibrary.org/obo/UPHENO_0003432> <http://purl.obolibrary.org/obo/UPHENO_0002963>)

# Class: <http://purl.obolibrary.org/obo/UPHENO_0004061> (hepatobiliary system phenotype)

SubClassOf(<http://purl.obolibrary.org/obo/UPHENO_0004061> <http://purl.obolibrary.org/obo/UPHENO_0002963>)

# Class: <http://purl.obolibrary.org/obo/UPHENO_0004064> (integumental system phenotype)

SubClassOf(<http://purl.obolibrary.org/obo/UPHENO_0004064> <http://purl.obolibrary.org/obo/UPHENO_0002963>)

# Class: <http://purl.obolibrary.org/obo/UPHENO_0004494> (sensory system phenotype)

SubClassOf(<http://purl.obolibrary.org/obo/UPHENO_0004494> <http://purl.obolibrary.org/obo/UPHENO_0002963>)

# Class: <http://purl.obolibrary.org/obo/UPHENO_1000001> (exocrine system phenotype)

AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/UPHENO_1000001> <https://orcid.org/0000-0003-4606-0597>)
AnnotationAssertion(dcterms:date <http://purl.obolibrary.org/obo/UPHENO_1000001> "2026-02-18T19:57:29Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/UPHENO_1000001> "UBERON:0002330")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UPHENO_1000001> "exocrine system phenotype")
SubClassOf(<http://purl.obolibrary.org/obo/UPHENO_1000001> <http://purl.obolibrary.org/obo/UPHENO_0002963>)

